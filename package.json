{
  "name": "playwright-automation",
  "version": "1.0.0",
  "description": "Playwright + TypeScript end-to-end test automation framework targeting SauceDemo",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:smoke": "playwright test --grep @smoke",
    "test:report": "playwright show-report",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "sync": "git fetch origin && git rebase origin/main"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jikkles/playwright-automation.git"
  },
  "keywords": [],
  "author": "Tom Newland",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Jikkles/playwright-automation/issues"
  },
  "homepage": "https://github.com/Jikkles/playwright-automation#readme",
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "allure-commandline": "^2.38.1",
    "allure-playwright": "^3.7.2",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-playwright": "^2.10.2",
    "prettier": "^3.8.3",
    "typescript-eslint": "^8.59.2"
  }
}
